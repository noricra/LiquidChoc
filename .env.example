# ════════════════════════════════════════════════════════════
# FICHIER TEMPLATE - COPIER EN .env ET REMPLACER LES VALEURS
# NE JAMAIS COMMITER DE VRAIS SECRETS SUR GIT
# ════════════════════════════════════════════════════════════

# ─── Serveur ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://votre-app.vercel.app

# ─── MongoDB ─────────────────────────────────────────────────
# LOCAL: mongodb://localhost:27017/liquidchoc-dev
# PROD: mongodb+srv://user:pass@cluster.mongodb.net/commerce-A
MONGODB_URI=mongodb://localhost:27017/liquidchoc-dev

# ─── Redis ───────────────────────────────────────────────────
# LOCAL: redis://localhost:6379
# PROD: redis://default:password@host:port (Upstash, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────
# Obtenir sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# LOCAL: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# PROD: Configurer dans Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Twilio ──────────────────────────────────────────────────
# Obtenir sur https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Cloudflare R2 Storage ───────────────────────────────────
# IMPORTANT: L'endpoint NE doit PAS contenir le nom du bucket
R2_SECRET_KEY=xxx
R2_APPLICATION_KEY=xxx
R2_BUCKET_NAME=liquidchoc-prod
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# ─── Setup Secret ────────────────────────────────────────────
SETUP_SECRET=changeme_avec_une_valeur_aléatoire

# ─── Backend Caméléon (Personnalisation par commerce) ───────
SECTOR=food  # food | games | services
BUSINESS_NAME=Mon Commerce
PRIMARY_COLOR=#006644
SECONDARY_COLOR=#F7F7F7
ACCENT_COLOR=#006644
MERCHANT_ADDRESS=123 Rue Principale, Ville
MERCHANT_PHONE=+15141234567
PICKUP_HOURS=18h-20h tous les jours
